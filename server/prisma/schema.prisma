generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id           String   @id @default(cuid())
  title        String
  description  String
  affectedPop  String
  region       String
  issueType    String
  suggestedSol String
  sdgTag       String?
  rationale    String?
  authorName   String
  createdAt    DateTime @default(now())
}
